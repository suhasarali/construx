{
  "expo": {
    "name": "construx",
    "slug": "construx",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.suhasarali.construx",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow construx to access your camera to take photos for attendance.",
          "microphonePermission": "Allow construx to access your microphone."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4e1c5b0b-d52f-4d1d-b937-b1ef10dcbf67"
      }
    }
  }
}
